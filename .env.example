# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Docker image (default: pre-built from GHCR)
# GRIMPORT_IMAGE=ghcr.io/boeldner/grimport:latest

# Domain where the Grimport panel is accessible
# Local dev:  grimport.localhost
# Production: panel.yourdomain.com
SUPERVISOR_DOMAIN=grimport.localhost

# Base domain for auto-generated site subdomains (optional)
# e.g. sites.yourdomain.com → abc123.sites.yourdomain.com
# Leave empty to disable
SITE_BASE_DOMAIN=

# Your server's public IP (optional — auto-detected if blank)
PUBLIC_IP=

# Secret key for session auth — change this to something random!
SUPERVISOR_SECRET=changeme

# Absolute path to the data/sites directory ON THE HOST
# Only needed when running in Portainer/Arcane (no PWD context).
# For docker compose on the host, leave commented out (auto-detected).
# HOST_DATA_PATH=/opt/grimport/data/sites

# ── SSL mode ──────────────────────────────────────────────────
#
# SSL_MODE=cloudflare  (default)
#   Cloudflare Tunnel handles SSL. No cert config needed.
#   In your tunnel: panel.yourdomain.com → http://webhost-supervisor:3000
#                   *.sites.yourdomain.com → http://webhost-traefik:80
#   Leave ACME_EMAIL empty and keep the SSL block commented in compose.
#
# SSL_MODE=letsencrypt
#   Traefik fetches certs directly via Let's Encrypt.
#   Requires: ports 80+443 open, DNS pointing to this server.
#   Set ACME_EMAIL below and uncomment the SSL block in docker-compose.yml.
#
ACME_EMAIL=

# Ports Traefik listens on
HTTP_PORT=80
HTTPS_PORT=443

# Environment
NODE_ENV=production
