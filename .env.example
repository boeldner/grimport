# Copy this to .env and adjust values

# Docker image to use (default: pre-built from GHCR, set to "build" to build locally)
# GRIMPORT_IMAGE=ghcr.io/boeldner/grimport:latest

# Domain where the supervisor GUI is accessible
# In local dev: grimport.localhost  (avoids Chrome's HSTS preload for bare "localhost")
# In production: e.g. panel.yourdomain.com
SUPERVISOR_DOMAIN=grimport.localhost

# Base domain for auto-generated site subdomains
# e.g. sites.yourdomain.com  →  <random>.sites.yourdomain.com
# Leave empty to disable auto-suggest
SITE_BASE_DOMAIN=

# Your server's public IP (optional — auto-detected if not set)
PUBLIC_IP=

# Email for Let's Encrypt SSL certificates (required in production)
ACME_EMAIL=

# Ports Traefik listens on
HTTP_PORT=80
HTTPS_PORT=443

# Secret key for supervisor API auth (change this!)
SUPERVISOR_SECRET=changeme

# Environment
NODE_ENV=development
